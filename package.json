{
  "name": "joinup",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install:client": "cd client && npm install --include=dev",
    "install:server": "cd server && npm install --include=dev",
    "install:all": "concurrently \"npm run install:server\" \"npm run install:client\"",
    "build": "npm run install:all && cd client && npm run build",
    "start": "cd server && npm start"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
